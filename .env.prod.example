# Copy to .env on the production server and fill in real values.
# .env is gitignored — never commit it.
#
# Production runs frontend and backend behind Caddy on the SAME domain
# (flypenza.ru) with path-based routing — /api, /admin, /media, /static,
# /ckeditor5 go to Django, everything else to Next.js. That means no CORS
# is actually exercised browser-side (same-origin), and SITE_URL/BACKEND_URL/
# NEXT_PUBLIC_* all collapse to the one public domain — unlike dev, where
# frontend (:3000) and backend (:8000) are different origins.

DOMAIN=flypenza.ru

# --- Django ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-random-secret
DEBUG=False
DJANGO_ALLOWED_HOSTS=flypenza.ru,www.flypenza.ru,backend
CSRF_TRUSTED_ORIGINS=https://flypenza.ru,https://www.flypenza.ru
CORS_ALLOWED_ORIGINS=https://flypenza.ru,https://www.flypenza.ru

# --- Postgres (change this password — the dev default is not safe for prod) ---
POSTGRES_DB=sletat
POSTGRES_USER=sletat
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgres://sletat:change-me-strong-password@db:5432/sletat

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Email (fill in once a real SMTP account exists; keep mock mode on until then) ---
EMAIL_MOCK_MODE=True
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@flypenza.ru
SALES_NOTIFICATION_EMAIL=sales@flypenza.ru
SEND_LEAD_CONFIRMATION_EMAIL=False
BACKEND_URL=https://flypenza.ru

# --- U-ON CRM integration ---
UON_MOCK_MODE=True
UON_API_BASE_URL=https://api.u-on.ru
UON_API_KEY=
# Optional shared secret checked against ?token= on the webhook receiver
# (POST /api/integrations/uon/webhook/, configured in U-ON's cabinet —
# Настройки → Интеграции → API/webhooks) — leave empty until confirmed
# whether U-ON supports a custom token in the webhook URL.
UON_WEBHOOK_SECRET=

# --- Telegram bot ---
TELEGRAM_BOT_ENABLED=False
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org

# --- Frontend ---
# Same domain as the backend in prod — Caddy splits by path, not by host/port.
NEXT_PUBLIC_API_BASE_URL=https://flypenza.ru
INTERNAL_API_BASE_URL=http://backend:8000
NEXT_PUBLIC_SITE_URL=https://flypenza.ru
