# Copy this file to .env and fill in real values before running docker compose.
# .env is gitignored — never commit real secrets.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-random-secret
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CSRF_TRUSTED_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Postgres (must run on a server located in the Russian Federation per 152-FZ in production) ---
POSTGRES_DB=sletat
POSTGRES_USER=sletat
POSTGRES_PASSWORD=sletat
DATABASE_URL=postgres://sletat:sletat@db:5432/sletat

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Email (SMTP provider not yet set up — leave mock mode on) ---
EMAIL_MOCK_MODE=True
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@sletat.ru
SALES_NOTIFICATION_EMAIL=sales@sletat.ru

# --- U-ON CRM integration (API key not yet issued — leave mock mode on) ---
UON_MOCK_MODE=True
UON_API_BASE_URL=https://api.u-on.ru
UON_API_KEY=

# --- Chat widget (final vendor not chosen yet) ---
CHAT_WIDGET_PROVIDER=none
CHAT_WIDGET_ID=

# --- Frontend ---
# NEXT_PUBLIC_API_BASE_URL is baked into the browser bundle — used by client components.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# INTERNAL_API_BASE_URL is used by server components (SSR), which run inside the
# frontend container and must reach the backend over the Docker network, not localhost.
INTERNAL_API_BASE_URL=http://backend:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
